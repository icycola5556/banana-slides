# OpenAI 配置
OPENAI_API_KEY=your-api-key-here
# 代理示例: https://api.openai.com/v1 或你自己的网关
OPENAI_API_BASE=https://api.openai.com/v1
# 超时时间（秒），默认300秒
OPENAI_TIMEOUT=300.0
# 最多重试次数，减少重试避免累积超时，默认2次
OPENAI_MAX_RETRIES=2

# AI 模型配置
TEXT_MODEL=gpt-4.1-mini
IMAGE_MODEL=wanx-v1

# HTML 生图 Prompt 优化（规则 + 小模型改写）
# 开关：true/false（建议本地先开）
IMAGE_PROMPT_REWRITE_ENABLED=true
# 可选：指定用于 prompt 改写的小模型；留空则复用 TEXT_MODEL
IMAGE_PROMPT_REWRITE_MODEL=
# 每次请求最多改写多少个 slot（避免过慢）
IMAGE_PROMPT_REWRITE_MAX_SLOTS=24
# 小模型改写的批大小（越大越省请求次数，但单次更重）
IMAGE_PROMPT_REWRITE_BATCH_SIZE=8
# 小模型思考预算（数值越大通常质量更高，但更慢）
IMAGE_PROMPT_REWRITE_THINKING_BUDGET=400

# 后端服务配置
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-this-in-production
PORT=5000
# 数据库连接（推荐直接用 DATABASE_URL）
DATABASE_URL=mysql+pymysql://root:change-me@127.0.0.1:3306/banana_slides?charset=utf8mb4
# 多用户登录账号（格式：账号:密码:用户ID，多个账号用逗号分隔）
# 例如：AUTH_USERS=alice:alice-pass:1,bob:bob-pass:2
AUTH_USERS=
TEACHERAI_INTERNAL_TOKEN=
# 生产 HTTPS 环境必须设为 true；本地开发保持 false 即可
AUTH_COOKIE_SECURE=false

# CORS 配置（多个地址用逗号分隔）
CORS_ORIGINS=*

# 并发配置
MAX_DESCRIPTION_WORKERS=5
# 描述批量生成大小（image 模式下每次请求生成几页）
# 默认 1（稳定优先）；需要提速可手动改成 2-4
DESCRIPTION_BATCH_SIZE=1
MAX_IMAGE_WORKERS=8

# 图片识别模型配置（用于参考文件中的图像描述）
IMAGE_CAPTION_MODEL=gpt-4.1-mini

# 输出语言配置
# 可选值: 'zh' (中文), 'ja' (日本語), 'en' (English), 'auto' (自动)
OUTPUT_LANGUAGE=zh

# --- 镜像源配置（国内用户如遇网络问题，取消以下注释即可使用国内镜像源）---

# #  Docker Hub 镜像源（注意末尾斜杠）
# DOCKER_REGISTRY=docker.1ms.run/

# # GitHub Container Registry 镜像源（注意末尾斜杠）
# GHCR_REGISTRY=ghcr.nju.edu.cn/

# # Debian apt 镜像源
# APT_MIRROR=mirrors.aliyun.com

# # PyPI 镜像源
# PYPI_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple

# # npm 镜像源（注意末尾斜杠）
# NPM_REGISTRY=https://registry.npmmirror.com/

# 前端调试按钮配置
# 设置为 true 时显示调试按钮（查看JSON、图片化生成等），默认隐藏
# VITE_SHOW_DEBUG_BUTTONS=true
